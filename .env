# ── Server ────────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ── LibreTranslate ────────────────────────────────────────────────────────────
# Primary public instance (no API key required)
LIBRETRANSLATE_URL=https://libretranslate.com/translate

# Fallback mirrors (used automatically if primary fails)
LIBRETRANSLATE_MIRROR_1=https://translate.argosopentech.com/translate
LIBRETRANSLATE_MIRROR_2=https://translate.terraprint.co/translate
LIBRETRANSLATE_MIRROR_3=https://libretranslate.de/translate

# Optional API key (leave empty if not required by your chosen instance)
LIBRETRANSLATE_API_KEY=

# ── Request settings ──────────────────────────────────────────────────────────
# Milliseconds before a translation request times out
REQUEST_TIMEOUT_MS=10000

# ── Rate limiting ─────────────────────────────────────────────────────────────
# Max requests per window per IP
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=30

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated allowed origins, or * for all
ALLOWED_ORIGINS=*